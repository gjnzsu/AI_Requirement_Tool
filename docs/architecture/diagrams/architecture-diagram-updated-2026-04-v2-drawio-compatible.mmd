flowchart TB
  subgraph RP["Request Path"]
    U["User"]
    W["Web UI<br/>web/templates + web/static"]
    F["Flask App<br/>app.py<br/>Routes + metrics + auth endpoints"]
    R["AppRuntime<br/>src/webapp/runtime.py<br/>request-scoped snapshot/restore"]
    C["Chatbot<br/>src/chatbot.py<br/>provider switching, memory, RAG wiring"]
    A["ChatbotAgent / LangGraph<br/>src/agent/agent_graph.py"]
    S["RequirementSdlcAgentService<br/>BA draft -> confirmation -> execution handoff"]
  end

  subgraph AC["Application Core"]
    BC["build_application_services()<br/>src/runtime/composition.py"]
    WF["RequirementWorkflowService<br/>lifecycle source of truth"]
    P["Application Ports<br/>src/application/ports<br/>JiraIssuePort / ConfluencePagePort / JiraEvaluationPort"]
    AD["Fallback Adapters<br/>src/adapters/*<br/>MCP-first + Direct fallback + DTO normalization"]
  end

  subgraph CAP["Capabilities"]
    MM["MemoryManager + MemorySummarizer"]
    RG["RAG Service"]
    CZ["Coze Client"]
    MCP["MCP Integration"]
    DT["Direct Tools<br/>JiraTool + ConfluenceTool"]
    LR["LLM Router + ProviderManager<br/>src/llm/router.py"]
    GW["Optional FastAPI AI Gateway<br/>src/gateway/gateway_service.py<br/>rate limit / cache / metrics / fallback"]
  end

  subgraph EXT["External / Storage"]
    ATL["Atlassian APIs<br/>Jira + Confluence"]
    COZEAPI["Coze Platform API"]
    LLMAPI["LLM Provider APIs<br/>OpenAI / Gemini / DeepSeek"]
    MEMDB["Memory DB<br/>SQLite"]
    VECDB["Vector DB<br/>ChromaDB"]
    AUTHDB["Auth DB<br/>SQLite"]
  end

  U --> W
  W --> F
  F --> R
  R --> C
  C --> A
  A -->|"agent_mode=requirement_sdlc_agent"| S

  C -. "compose" .-> BC
  A -. "compose" .-> BC
  BC --> WF
  WF --> P
  P --> AD
  S -->|"execution handoff"| WF

  C --> MM
  A --> RG
  A --> CZ
  C --> LR
  AD --> MCP
  AD --> DT

  F --> AUTHDB
  MM --> MEMDB
  RG --> VECDB
  CZ --> COZEAPI
  LR --> LLMAPI
  MCP -. "MCP path" .-> ATL
  DT -. "direct fallback" .-> ATL

  C -. "optional USE_GATEWAY" .-> GW
  GW -.-> LLMAPI
